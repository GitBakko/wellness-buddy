{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:4173/login",
        "http://localhost:4173/today",
        "http://localhost:4173/settimana/2026-05-04",
        "http://localhost:4173/spesa/2026-05-04",
        "http://localhost:4173/piano",
        "http://localhost:4173/impostazioni"
      ],
      "startServerCommand": "pnpm preview --port 4173",
      "startServerReadyPattern": "Local",
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "skipAudits": ["uses-http2", "canonical"]
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:pwa": ["error", { "minScore": 1.0 }],
        "categories:performance": ["warn", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
