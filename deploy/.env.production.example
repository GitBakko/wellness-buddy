# Wellness Buddy — production .env example
# Copy to backend/.env on the server, fill REAL values, NEVER commit.
# Generate secrets via: pwsh deploy/scripts/generate-secrets.ps1
# Encrypt at rest via DPAPI + ACL lockdown (see DEPLOY.md §3).

# ─── Database (D-29 pool 15/10) ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://wnbd:CHANGE_ME@localhost:5432/WellnessBuddy

# ─── JWT (D-24) ─────────────────────────────────────────────────────
# 32-byte hex (64 chars) from generate-secrets.ps1 — never commit
SECRET_KEY=CHANGE_ME_32_BYTE_HEX_FROM_generate-secrets.ps1
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS (validated at boot — never wildcard in prod) ──────────────
CORS_ORIGINS=https://wellness-buddy.epartner.it

# ─── AI provider stub (D-31, AI-07) ─────────────────────────────────
AI_PROVIDER=null

# ─── Operational ────────────────────────────────────────────────────
MAX_USERS=100
ADMIN_EMAIL=s.brunelli@epartner.it
LOG_LEVEL=INFO
SQL_ECHO=false
APP_VERSION=0.1.0
BUILD_HASH=CHANGE_ME_GIT_SHA
TZ=Europe/Rome
