# Wellness Buddy backend env — copy to backend/.env and fill real values
# NEVER commit backend/.env

# Database (D-29 pool 15/10)
DATABASE_URL=postgresql+asyncpg://wnbd:WnBd4321@@localhost:5432/WellnessBuddy

# JWT secrets (D-24 — generate via: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=changeme-32-byte-token-hex-generate-with-secrets-token_hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (validated at boot — never wildcard in prod)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AI provider stub (D-31, AI-07)
AI_PROVIDER=null

# Phase 2 — PDF export backend (DEP-06, D-11)
# Default 'weasyprint'. Flip to 'reportlab' if Plan 02-01 GTK3 spike fails 5xx >2% threshold.
PDF_BACKEND=weasyprint

# Operational
MAX_USERS=100
ADMIN_EMAIL=admin@example.com
LOG_LEVEL=INFO
SQL_ECHO=false
APP_VERSION=0.1.0
BUILD_HASH=dev
